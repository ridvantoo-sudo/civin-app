# Add these values in Back4app Containers > Settings > Environment Variables.
# Do not upload this file or commit real credentials.
APP_NAME=Civin
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate_show
APP_DEBUG=false
APP_URL=https://YOUR_BACK4APP_HOST
FRONTEND_URL=https://YOUR_FRONTEND_HOST

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_MAINTENANCE_DRIVER=cache
APP_MAINTENANCE_STORE=redis
BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_LEVEL=warning

# Back4app Containers do not include a relational database. Use managed MySQL.
DB_CONNECTION=mysql
DB_HOST=YOUR_MYSQL_HOST
DB_PORT=3306
DB_DATABASE=civin
DB_USERNAME=civin
DB_PASSWORD=CHANGE_ME
# Set this to the provider CA file path only when the provider requires one.
MYSQL_ATTR_SSL_CA=

# A shared Redis service is required for cache locks, queues, and safe scaling.
CACHE_STORE=redis
QUEUE_CONNECTION=redis
REDIS_CLIENT=predis
REDIS_HOST=YOUR_REDIS_HOST
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=CHANGE_ME
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE=default

SESSION_DRIVER=database
SESSION_ENCRYPT=true
SESSION_DOMAIN=YOUR_BACK4APP_HOST
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SANCTUM_EXPIRATION=60
REFRESH_TOKEN_EXPIRATION_DAYS=30
SANCTUM_STATEFUL_DOMAINS=YOUR_BACK4APP_HOST

# Back4app's container filesystem is ephemeral. The current app stores media
# URLs rather than uploaded files; configure an object-store disk before adding
# local uploads.
FILESYSTEM_DISK=local

# Store the service-account JSON as one base64 string in the dashboard:
# base64 < firebase-service-account.json | tr -d '\n'
FIREBASE_CREDENTIALS_BASE64=

AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
AGORA_TOKEN_TTL=3600

BROADCAST_CONNECTION=log
BROADCAST_HOST=
BROADCAST_PORT=443
BROADCAST_SCHEME=https
BROADCAST_APP_ID=
BROADCAST_APP_KEY=
BROADCAST_APP_SECRET=

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=Civin

# The Back4app image supervises these processes alongside Apache.
BACK4APP_RUN_QUEUE_WORKER=true
BACK4APP_RUN_SCHEDULER=true

# Keep migrations enabled for normal deployments. The shared Redis lock
# prevents multiple replicas from migrating concurrently.
BACK4APP_RUN_MIGRATIONS=true

# Enable for the first deployment, then turn it off after reference data exists.
BACK4APP_RUN_SEEDERS=false
